<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F9F9F9">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Transaction"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#24389C"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/friendIdEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Friend ID / Email"
        android:inputType="textEmailAddress"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/amountEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount (₹)"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginBottom="24dp"/>

    <RadioGroup
        android:id="@+id/oweRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        
        <RadioButton
            android:id="@+id/theyOweMeRadio"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="They Owe Me"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/iOweThemRadio"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="I Owe Them"/>
    </RadioGroup>

    <Button
        android:id="@+id/saveBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Transaction"
        android:backgroundTint="#24389C"
        android:padding="12dp"/>

    <ProgressBar
        android:id="@+id/progressBarTx"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_gravity="center"
        android:visibility="gone"/>

</LinearLayout>
